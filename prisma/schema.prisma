generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== الأدوار ====================

model Role {
  role_id   String @id @default(cuid())
  role_name String @unique // visitor | user | seller | admin
  users     User[]
}

// ==================== المستخدمون ====================

model User {
  user_id      String @id @default(cuid())
  name         String
  email        String @unique
  phone        String?
  password_hash String?
  role_id      String @default("visitor")
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  role          Role          @relation(fields: [role_id], references: [role_id])
  products      Product[]
  cart          Cart?
  orders        Order[]
  notifications Notification[]
}

// ==================== المنتجات ====================

model Product {
  product_id   String   @id @default(cuid())
  seller_id    String?
  name         String
  description  String
  price        Float
  category     String
  images       String   @default("[]")
  availability Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  seller     User?      @relation(fields: [seller_id], references: [user_id])
  cartItems  CartItem[]
  orderItems OrderItem[]
}

// ==================== السلة ====================

model Cart {
  cart_id    String @id @default(cuid())
  user_id    String @unique
  created_at DateTime @default(now())

  user    User       @relation(fields: [user_id], references: [user_id])
  cartItems CartItem[]
}

// ==================== عناصر السلة ====================

model CartItem {
  cartitemid  String @id @default(cuid())
  cart_id     String
  product_id  String
  quantity    Int    @default(1)

  cart    Cart    @relation(fields: [cart_id], references: [cart_id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [product_id])
}

// ==================== الطلبات ====================

model Order {
  order_id   String   @id @default(cuid())
  user_id    String
  status     String   @default("new") // new | reviewing | confirmed | shipped | cancelled
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user       User        @relation(fields: [user_id], references: [user_id])
  orderItems OrderItem[]
}

// ==================== بنود الطلب ====================

model OrderItem {
  orderitemid String @id @default(cuid())
  order_id    String
  product_id  String
  quantity    Int
  price       Float
  created_at  DateTime @default(now())

  order   Order   @relation(fields: [order_id], references: [order_id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [product_id])
}

// ==================== الإشعارات ====================

model Notification {
  notification_id String   @id @default(cuid())
  user_id         String
  type            String   @default("info")
  message         String
  status          String   @default("unread")
  created_at      DateTime @default(now())

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}
